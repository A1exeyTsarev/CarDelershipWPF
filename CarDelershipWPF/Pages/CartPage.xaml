<Page x:Class="CarDelershipWPF.Pages.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Корзина"
      Background="#1a1a1a"
      Width="1200"
      Height="800">

    <Grid Background="#1a1a1a">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#2a2a2a" Padding="15" BorderBrush="#FFC107" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Кнопка назад -->
                <Button Grid.Column="0" Content="◀ Назад в магазин" 
                        Background="#333333" Foreground="#FFC107"
                        BorderBrush="#FFC107" BorderThickness="1"
                        Height="35" Width="130" Click="BtnBack_Click"/>

                <!-- Заголовок -->
                <TextBlock Grid.Column="1" Text="🛒 Моя корзина" 
                           FontSize="24" FontWeight="Bold" Foreground="#FFC107"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- Информация о пользователе -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="txtUserInfo" Foreground="#FFC107" Margin="0,0,10,0"/>
                    <Button x:Name="btnLogout" Content="🚪 Выйти" 
                            Background="#333333" Foreground="#FF6B6B"
                            BorderBrush="#FF6B6B" BorderThickness="1"
                            Height="35" Padding="15,0"
                            Click="BtnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Список товаров в корзине -->
        <ScrollViewer Grid.Row="1" Margin="15">
            <ListView x:Name="lvCart" Background="Transparent" BorderThickness="0">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,10"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2a2a2a" CornerRadius="10" Padding="15"
                                BorderBrush="#FFC107" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Изображение -->
                                <Border Grid.Column="0" Width="120" Height="80" 
                                        Background="#1a1a1a" CornerRadius="8"
                                        BorderBrush="#FFC107" BorderThickness="1">
                                    <Image Source="{Binding ImagePath}" 
                                           Width="120" Height="80" 
                                           Stretch="Uniform"/>
                                </Border>

                                <!-- Название -->
                                <TextBlock Grid.Column="1" Text="{Binding CarName}" 
                                           FontSize="16" FontWeight="Bold" 
                                           Foreground="#FFC107" VerticalAlignment="Center"
                                           Margin="15,0,0,0"/>

                                <!-- Цена -->
                                <TextBlock Grid.Column="2" Text="{Binding Price, StringFormat={}{0:N0} ₽}" 
                                           Foreground="#888" VerticalAlignment="Center" 
                                           TextAlignment="Center"/>

                                <!-- Количество -->
                                <StackPanel Grid.Column="3" Orientation="Horizontal" 
                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button Content="-" Width="30" Height="30" 
                                            Background="#DC3545" Foreground="White"
                                            FontWeight="Bold" FontSize="16"
                                            Click="BtnDecrease_Click" Tag="{Binding}"/>
                                    <TextBlock Text="{Binding Quantity}" Width="50" TextAlignment="Center" 
                                               Foreground="White" FontSize="16" FontWeight="Bold"/>
                                    <Button Content="+" Width="30" Height="30" 
                                            Background="#28A745" Foreground="White"
                                            FontWeight="Bold" FontSize="16"
                                            Click="BtnIncrease_Click" Tag="{Binding}"/>
                                </StackPanel>

                                <!-- Удалить -->
                                <Button Grid.Column="4" Content="🗑️" Width="40" Height="40" 
                                        Background="#333333" Foreground="#FF6B6B" 
                                        BorderBrush="#FF6B6B" BorderThickness="1"
                                        FontSize="18" Click="BtnRemove_Click" Tag="{Binding}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>

        <!-- Итоговая панель -->
        <Border Grid.Row="2" Background="#2a2a2a" Padding="15" Margin="15" CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock FontSize="14" Foreground="#888">
                        <Run Text="Товаров: "/>
                        <Run x:Name="txtTotalItems" Text="0"/>
                    </TextBlock>
                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="#FFC107">
                        <Run Text="Итого: "/>
                        <Run x:Name="txtTotalPrice" Text="0"/> ₽
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="btnClearCart" Content="🗑️ Очистить корзину" 
                            Background="#DC3545" Foreground="White"
                            Height="45" Width="150" Margin="0,0,10,0"
                            FontWeight="Bold" Click="BtnClearCart_Click"/>
                    <Button x:Name="btnCheckout" Content="✅ Оформить заказ" 
                            Background="#28A745" Foreground="White"
                            Height="45" Width="180" FontWeight="Bold"
                            Click="BtnCheckout_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>