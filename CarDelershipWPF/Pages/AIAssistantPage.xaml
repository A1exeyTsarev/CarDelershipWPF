<Page x:Class="CarDelershipWPF.Pages.AIAssistantPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AI Помощник"
      Background="#1a1a1a"
      Width="900"
      Height="650">

    <Grid Background="#1a1a1a">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2a2a2a" Padding="15" BorderBrush="#FFC107" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="◀ Назад" 
                        Background="#333" Foreground="#FFC107"
                        BorderBrush="#FFC107" BorderThickness="1"
                        Height="35" Width="100" Click="BtnBack_Click" Cursor="Hand"/>

                <TextBlock Grid.Column="1" Text="🤖 AI Помощник CarDelership" 
                           FontSize="24" FontWeight="Bold" Foreground="#FFC107"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="2" Width="100" Visibility="Hidden"/>
            </Grid>
        </Border>

        <!-- Чат -->
        <ScrollViewer Grid.Row="1" x:Name="ChatScroller" Margin="15" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ChatPanel"/>
        </ScrollViewer>

        <!-- Панель ввода -->
        <Border Grid.Row="2" Background="#2a2a2a" Padding="15" Margin="15,0,15,15" CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtInput" Grid.Column="0"
                         Background="#333" Foreground="White"
                         BorderBrush="#FFC107" BorderThickness="1"
                         Padding="10" Height="40" FontSize="13"
                         KeyDown="TxtInput_KeyDown"/>

                <Button x:Name="btnSend" Grid.Column="1"
                        Content="📤 Отправить" Background="#FFC107" Foreground="Black"
                        BorderBrush="#FFC107" BorderThickness="1"
                        Width="100" Height="40" Margin="10,0,0,0"
                        FontSize="14" FontWeight="Bold" Click="BtnSend_Click" Cursor="Hand"/>
            </Grid>
        </Border>
    </Grid>
</Page>