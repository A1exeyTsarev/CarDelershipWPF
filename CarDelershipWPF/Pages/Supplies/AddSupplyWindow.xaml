<Window x:Class="CarDelershipWPF.Pages.AddSupplyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание поставки" Height="650" Width="800"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1a1a1a">

    <Window.Resources>
        <!-- Стиль для светлого ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#FFC107"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <!-- Стиль для элементов ComboBox -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFC107"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFC107"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFC107"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="5,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#FFC107"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для TextBlock -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFC107"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Стиль для DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#2a2a2a"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="RowBackground" Value="#2a2a2a"/>
            <Setter Property="AlternatingRowBackground" Value="#333333"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFC107"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2a2a2a"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#2a2a2a"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#404040"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопки -->
        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- Стиль для Border -->
        <Style TargetType="Border">
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Создание поставки" FontSize="22" FontWeight="Bold" 
                   Foreground="#FFC107" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Данные поставки -->
        <Border Grid.Row="1" Background="#2a2a2a" CornerRadius="10" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Поставщик:" Margin="5"/>
                <ComboBox x:Name="cmbSupplier" Grid.Row="0" Grid.Column="1" Margin="5"
                          DisplayMemberPath="Name" SelectedValuePath="Supplier_Id"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Статус:" Margin="5"/>
                <ComboBox x:Name="cmbStatus" Grid.Row="0" Grid.Column="3" Margin="5"
                          DisplayMemberPath="StatusName" SelectedValuePath="StatusSupply_Id"/>
            </Grid>
        </Border>

        <!-- Добавление товаров -->
        <Border Grid.Row="2" Background="#2a2a2a" CornerRadius="10" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Товары в поставке" FontSize="15" FontWeight="Bold" 
                           Foreground="#FFC107" Margin="0,0,0,15"/>

                <!-- Панель добавления товара -->
                <Border Grid.Row="1" Background="#333333" CornerRadius="8" Padding="10" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="cmbProduct" Grid.Column="0" Margin="0,0,10,0"
                                  DisplayMemberPath="Name" SelectedValuePath="Car_Id"/>

                        <TextBox x:Name="txtQuantity" Grid.Column="1" 
                                 Tag="Количество" Margin="0,0,10,0"
                                 PreviewTextInput="NumberOnly_PreviewTextInput"/>

                        <Button x:Name="btnAddItem" Grid.Column="2" Content="➕ Добавить товар" Width="130" Height="35"
                                Background="#FFC107" Foreground="Black" FontWeight="Bold"
                                Click="btnAddItem_Click" Cursor="Hand"/>
                    </Grid>
                </Border>

                <!-- Таблица товаров в поставке -->
                <DataGrid x:Name="dgItems" Grid.Row="2" AutoGenerateColumns="False"
                          SelectionMode="Single" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Наименование товара" Binding="{Binding ProductName}" Width="400"/>
                        <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="120"/>
                        <DataGridTemplateColumn Header="Действия" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="🗑️" Width="40" Height="28" 
                                            Click="btnRemoveItem_Click" Tag="{Binding}"
                                            Background="#DC3545" Foreground="White" Cursor="Hand"
                                            FontSize="12" ToolTip="Удалить"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Кнопки -->
        <Border Grid.Row="3" Background="#2a2a2a" CornerRadius="10" Padding="15" Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnSave" Content="💾 Сохранить поставку" Width="150" Height="40"
                        Background="#FFC107" Foreground="Black" FontWeight="Bold"
                        Click="btnSave_Click" Margin="0,0,15,0" Cursor="Hand"/>
                <Button x:Name="btnCancel" Content="❌ Отмена" Width="120" Height="40"
                        Background="#333" Foreground="#FFC107" FontWeight="Bold"
                        Click="btnCancel_Click" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>