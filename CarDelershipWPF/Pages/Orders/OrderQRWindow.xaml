<Window x:Class="CarDelershipWPF.Pages.OrderQRWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QR-код заказа"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Width="500"
        Height="700"
        Background="#1a1a1a">

    <Grid Background="#1a1a1a" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2a2a2a" CornerRadius="10" Padding="15" Margin="0,0,0,15">
            <TextBlock Text="QR-код заказа" FontSize="20" FontWeight="Bold" 
                       Foreground="#FFC107" HorizontalAlignment="Center"/>
        </Border>

        <!-- Информация о заказе -->
        <Border Grid.Row="1" Background="#2a2a2a" CornerRadius="10" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock FontSize="14" Foreground="#FFC107" FontWeight="Bold" Margin="0,0,0,8">
                    <Run Text="Номер заказа: "/><Run x:Name="txtOrderNumber"/>
                </TextBlock>
                <TextBlock FontSize="14" Foreground="#888" Margin="0,0,0,5">
                    <Run Text="Статус: "/><Run x:Name="txtStatus"/>
                </TextBlock>
                <TextBlock FontSize="14" Foreground="#888" Margin="0,0,0,5">
                    <Run Text="Клиент: "/><Run x:Name="txtCustomer"/>
                </TextBlock>
                <TextBlock FontSize="14" Foreground="#FFC107" FontWeight="Bold" Margin="0,10,0,0">
                    <Run Text="Сумма: "/><Run x:Name="txtTotalAmount"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- QR-код -->
        <Border Grid.Row="2" Background="#2a2a2a" CornerRadius="10" Padding="15">
            <StackPanel>
                <TextBlock Text="Отсканируйте QR-код" FontSize="15" FontWeight="Bold" 
                           Foreground="#FFC107" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <!-- Увеличен размер QR-кода -->
                <Image x:Name="imgQR" Width="300" Height="300" 
                       HorizontalAlignment="Center" Margin="10"
                       RenderOptions.BitmapScalingMode="HighQuality"/>

                <TextBlock Text="Информация о заказе" 
                           FontSize="11" Foreground="#888" TextAlignment="Center" 
                           Margin="0,15,0,0"/>

                <TextBlock Text="Отсканируйте QR-код камерой телефона" 
                           FontSize="10" Foreground="#666" TextAlignment="Center" 
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Кнопка закрытия -->
        <StackPanel Grid.Row="3" Margin="0,20,0,0" HorizontalAlignment="Center">
            <Button Content="◀ Закрыть" Width="150" Height="35"
                    Background="#333" Foreground="#FFC107" BorderBrush="#FFC107"
                    BorderThickness="1" Click="BtnClose_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>