<Page x:Class="CarDelershipWPF.Pages.MainShopPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Главная"
      Background="#1a1a1a"
      Width="1000"
      Height="800">

    <Grid Background="#1a1a1a">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#2a2a2a" Padding="15" BorderBrush="#FFC107" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Width="40" Height="40" Background="#FFC107" CornerRadius="20" Margin="0,0,10,0">
                        <TextBlock Text="C" FontSize="24" FontWeight="Bold" Foreground="Black"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="CarDelership" FontSize="16" FontWeight="Bold" Foreground="#FFC107"/>
                        <TextBlock Text="Автомобили с доставкой" FontSize="10" Foreground="#888"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="txtUserInfo" Foreground="#FFC107" Margin="0,0,10,0"/>
                    <TextBlock x:Name="txtUserRole" Foreground="#888" Margin="0,0,15,0"/>

                    <!-- 🆕 Кнопка AI помощника -->
                    <Button x:Name="btnAI" Content="🤖 AI Помощник" 
            Background="#333333" Foreground="#FFC107"
            BorderBrush="#FFC107" BorderThickness="1"
            Height="35" Padding="15,0" Margin="0,0,10,0"
            Click="BtnAI_Click" Cursor="Hand"/>

                    <!-- Кнопка корзины -->
                    <Button x:Name="btnCart" Content="🛒 Корзина" 
                            Background="#333333" Foreground="#FFC107"
                            BorderBrush="#FFC107" BorderThickness="1"
                            Height="35" Padding="15,0" Margin="0,0,10,0"
                            Click="BtnCart_Click"/>

                    <Button x:Name="btnDashboard" Content="⚙️ Панель управления"
                            Background="#333333" Foreground="#FFC107"
                            BorderBrush="#FFC107" BorderThickness="1"
                            Height="35" Padding="15,0" Margin="0,0,10,0"
                            Click="BtnDashboard_Click"
                            Visibility="Collapsed"/>

                    <Button x:Name="btnLogout" Content="🚪 Выйти"
                            Background="#333333" Foreground="#FF6B6B"
                            BorderBrush="#FF6B6B" BorderThickness="1"
                            Height="35" Padding="15,0"
                            Click="BtnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Панель фильтрации -->
        <Border Grid.Row="1" Background="#2a2a2a" Padding="15" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Поиск" Foreground="White" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtSearch" Height="30" TextChanged="TxtSearch_TextChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Производитель" Foreground="White" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbManufacturer" Height="30" SelectionChanged="CmbManufacturer_SelectionChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="Сортировка" Foreground="White" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbSort" Height="30" SelectionChanged="CmbSort_SelectionChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="3" VerticalAlignment="Bottom">
                    <Button x:Name="btnReset" Content="🔄 Сбросить"
                            Background="#333333" Foreground="#FFC107"
                            BorderBrush="#FFC107" BorderThickness="1"
                            Height="30" Padding="15,0"
                            Click="BtnReset_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Список товаров ListView -->
        <ListView x:Name="lvCars" 
                  Grid.Row="2"
                  Margin="15" 
                  Background="Transparent" 
                  BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,10"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="#2a2a2a" CornerRadius="10" Padding="15"
                            BorderBrush="#FFC107" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Изображение -->
                            <Border Grid.Column="0" Width="180" Height="120" 
                                    Background="#1a1a1a" CornerRadius="8"
                                    BorderBrush="#FFC107" BorderThickness="1">
                                <Image Source="{Binding ImagePath}" 
                                       Width="180" Height="120" 
                                       Stretch="Uniform"
                                       StretchDirection="Both"/>
                            </Border>

                            <!-- Информация об автомобиле -->
                            <StackPanel Grid.Column="1" Margin="15,0">
                                <TextBlock FontSize="18" FontWeight="Bold" Foreground="#FFC107"
                                           Text="{Binding Car.Name}"/>

                                <WrapPanel Margin="0,10,0,0">
                                    <TextBlock Foreground="#888" Margin="0,0,20,5">
                                        <Run Text="📅 Год: "/><Run Text="{Binding Car.Year}"/>
                                    </TextBlock>
                                    <TextBlock Foreground="#888" Margin="0,0,20,5">
                                        <Run Text="🎨 Цвет: "/><Run Text="{Binding Car.Colors.Name}"/>
                                    </TextBlock>
                                    <TextBlock Foreground="#888" Margin="0,0,20,5">
                                        <Run Text="📦 В наличии: "/><Run Text="{Binding Car.Quantity}"/> шт.
                                    </TextBlock>
                                    <TextBlock Foreground="#888" Margin="0,0,20,5">
                                        <Run Text="🔧 Двигатель: "/>
                                        <Run Text="{Binding Car.Models.EngineTypes.Name}"/>
                                        <Run Text=" ("/>
                                        <Run Text="{Binding Car.Models.Power}"/>
                                        <Run Text=" л.с.)"/>
                                    </TextBlock>
                                    <TextBlock Foreground="#888" Margin="0,0,20,5">
                                        <Run Text="⚙️ Коробка: "/><Run Text="{Binding Car.Models.Transmissions.Name}"/>
                                    </TextBlock>
                                    <TextBlock Foreground="#888" Margin="0,0,20,5">
                                        <Run Text="🚘 Кузов: "/><Run Text="{Binding Car.Models.BodyTypes.Name}"/>
                                    </TextBlock>
                                </WrapPanel>
                            </StackPanel>

                            <!-- Цена и кнопки -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock FontSize="24" FontWeight="Bold" Foreground="#FFC107" TextAlignment="Right">
                                    <Run Text="{Binding Car.DiscountPrice, Mode=OneWay, StringFormat={}{0:N0}}"/> ₽
                                </TextBlock>

                                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                                    <!-- Кнопка "В корзину" -->
                                    <Button Content="🛒 В корзину"
                                            Background="#28A745" Foreground="White"
                                            Height="35" Width="100" Margin="0,0,10,0"
                                            Click="BtnAddToCart_Click"
                                            Tag="{Binding}"/>

                                    <!-- Кнопка "Подробнее" -->
                                    <Button Content="📖 Подробнее"
                                            Background="#FFC107" Foreground="Black"
                                            Height="35" Width="100"
                                            Click="BtnDetails_Click"
                                            Tag="{Binding}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>