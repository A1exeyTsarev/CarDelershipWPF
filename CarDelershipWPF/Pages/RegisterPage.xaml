<Page x:Class="CarDelershipWPF.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Регистрация"
      Background="#1a1a1a"
      Width="500"
      Height="600">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Background="#1a1a1a" Margin="15,10">
            <StackPanel>
                <!-- Заголовок -->
                <TextBlock Text="Регистрация нового пользователя" 
                           FontSize="16" FontWeight="Bold" 
                           Foreground="#FFC107" TextAlignment="Center" Margin="0,0,0,12"/>

                <!-- ФИО -->
                <TextBlock Text="ФИО *" Foreground="White" FontSize="11" Margin="0,0,0,2"/>
                <TextBox x:Name="txtFullName" Height="30" FontSize="12" Margin="0,0,0,5"/>
                <TextBlock x:Name="txtFullNameError" Foreground="#FF6B6B" FontSize="9" Visibility="Collapsed" Margin="0,-3,0,3"/>

                <!-- Логин -->
                <TextBlock Text="Логин *" Foreground="White" FontSize="11" Margin="0,0,0,2"/>
                <TextBox x:Name="txtLogin" Height="30" FontSize="12" Margin="0,0,0,5"/>
                <TextBlock x:Name="txtLoginError" Foreground="#FF6B6B" FontSize="9" Visibility="Collapsed" Margin="0,-3,0,3"/>

                <!-- Пароль -->
                <TextBlock Text="Пароль *" Foreground="White" FontSize="11" Margin="0,0,0,2"/>
                <PasswordBox x:Name="txtPassword" Height="30" FontSize="12" Margin="0,0,0,5"/>
                <TextBlock x:Name="txtPasswordError" Foreground="#FF6B6B" FontSize="9" Visibility="Collapsed" Margin="0,-3,0,3"/>

                <!-- Подтверждение пароля -->
                <TextBlock Text="Подтверждение пароля *" Foreground="White" FontSize="11" Margin="0,0,0,2"/>
                <PasswordBox x:Name="txtConfirmPassword" Height="30" FontSize="12" Margin="0,0,0,5"/>
                <TextBlock x:Name="txtConfirmError" Foreground="#FF6B6B" FontSize="9" Visibility="Collapsed" Margin="0,-3,0,3"/>

                <!-- Телефон -->
                <TextBlock Text="Телефон" Foreground="White" FontSize="11" Margin="0,0,0,2"/>
                <TextBox x:Name="txtPhone" Height="30" FontSize="12" Margin="0,0,0,5"
                         ToolTip="+7 (XXX) XXX-XX-XX"/>
                <TextBlock x:Name="txtPhoneError" Foreground="#FF6B6B" FontSize="9" Visibility="Collapsed" Margin="0,-3,0,3"/>

                <!-- Email -->
                <TextBlock Text="Email" Foreground="White" FontSize="11" Margin="0,0,0,2"/>
                <TextBox x:Name="txtEmail" Height="30" FontSize="12" Margin="0,0,0,5"
                         ToolTip="example@mail.com"/>
                <TextBlock x:Name="txtEmailError" Foreground="#FF6B6B" FontSize="9" Visibility="Collapsed" Margin="0,-3,0,3"/>

                <!-- Паспортные данные -->
                <TextBlock Text="Паспортные данные" Foreground="White" FontSize="11" Margin="0,0,0,2"/>
                <TextBox x:Name="txtPassportData" Height="30" FontSize="12" Margin="0,0,0,12"/>

                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="btnRegister" Content="Зарегистрироваться" 
                            Background="#28A745" Foreground="White"
                            Height="36" Width="180" Margin="0,0,8,0"
                            FontSize="13" FontWeight="Bold"
                            Click="BtnRegister_Click"/>
                    <Button x:Name="btnCancel" Content="Отмена" 
                            Background="#333333" Foreground="#FFC107"
                            Height="36" Width="100"
                            FontSize="13" FontWeight="Bold"
                            Click="BtnBack_Click"/>
                </StackPanel>

                <TextBlock Text="* - обязательные поля" FontSize="9" 
                           Foreground="#888" Margin="0,10,0,0" TextAlignment="Center"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>